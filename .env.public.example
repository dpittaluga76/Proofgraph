# Copy this file to .env.public. Never commit or paste the completed file.
# Use a URL-safe PostgreSQL password so DATABASE_URL does not require percent-encoding.
POSTGRES_DB=proofgraph
POSTGRES_USER=proofgraph
POSTGRES_PASSWORD=GENERATE_A_LONG_RANDOM_PASSWORD
DATABASE_URL=postgresql://proofgraph:GENERATE_A_LONG_RANDOM_PASSWORD@db:5432/proofgraph
DATABASE_CONN_MAX_AGE=60

DJANGO_DEBUG=false
DJANGO_SECRET_KEY=GENERATE_A_DIFFERENT_LONG_RANDOM_SECRET
DJANGO_ALLOWED_HOSTS=proofgraph.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://proofgraph.example.com
DEMO_PUBLIC_MODE=true

# Server-side only. Leave empty until a minimal hybrid run is explicitly authorized.
OPENAI_API_KEY=
